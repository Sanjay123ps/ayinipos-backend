# Copy this file to .env for local development. On Railway (or wherever you
# deploy), set these as actual environment variables in the project's
# dashboard instead — .env files are for local use only.

# --- Database ---------------------------------------------------------------
# Railway's Postgres plugin sets DATABASE_URL for you automatically once you
# attach it to this service — you shouldn't need to set it by hand there.
# For local development, either set DATABASE_URL directly, or leave it unset
# and fill in the PG* fallbacks below (src/config/db.js uses PGHOST/PGPORT/
# PGUSER/PGPASSWORD/PGDATABASE if DATABASE_URL isn't present).
# DATABASE_URL=postgres://user:password@host:5432/database
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=ayini_pos

# --- Auth ---------------------------------------------------------------
# Any long random string — used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this invalidates every existing logged-in session.
JWT_SECRET=change-this-to-a-long-random-string

# Used only once, by `npm run db:seed`, to create the first admin login.
# Change these before running it the first time in production — anyone who
# knows the default admin123 could otherwise log in.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123

# --- Server ---------------------------------------------------------------
PORT=4000
NODE_ENV=production

# Comma-free single origin (or * for any origin, fine for early testing but
# not recommended once this is handling real sales) — set this to your
# deployed frontend's exact URL, e.g. https://ayinipos.vercel.app
CORS_ORIGIN=*
